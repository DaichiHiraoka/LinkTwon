{
  "name": "linktown-partner-portals",
  "version": "0.1.0",
  "private": true,
  "description": "Event organizer and store QR portals for LinkTwon.",
  "main": "server.js",
  "scripts": {
    "dev:event": "node scripts/startPortal.js event 5181",
    "dev:store": "node scripts/startPortal.js store 5182",
    "dev": "concurrently -k -n event,store -c cyan,magenta \"npm run dev:event\" \"npm run dev:store\"",
    "start:event": "node scripts/startPortal.js event 5181",
    "start:store": "node scripts/startPortal.js store 5182",
    "start": "npm run dev",
    "env:check": "node scripts/checkEnv.js",
    "test": "node test/smoke-test.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "concurrently": "^9.2.1",
    "mysql2": "^3.22.5"
  }
}
