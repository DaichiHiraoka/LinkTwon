APP_ENV=development
NODE_ENV=development
PARTNER_APP_ROLE=event
PORT=5181

# Local development can share backend's SQLite database.
PARTNER_DB_CLIENT=sqlite
PARTNER_DB_PATH=../backend/database/dev.sqlite
PARTNER_SEED_DEMO_DATA=true

# Staging/production must use the same persistent MySQL database as backend.
# PARTNER_DB_CLIENT=mysql
# PARTNER_DATABASE_URL=mysql://user:password@host:3306/database?ssl-mode=REQUIRED
# PARTNER_DB_CONNECTION_LIMIT=10
# MYSQL_SSL=false
# MYSQL_SSL_REJECT_UNAUTHORIZED=true
# MYSQL_SSL_CA=/absolute/path/to/ca.pem

# Optional. If set, POST /api/translations/refresh requires x-refresh-key.
# PARTNER_REFRESH_KEY=replace-with-refresh-key
# Optional external translation API. Do not commit real tokens.
# Local default points at the main backend translation cache.
TRANSLATION_API_URL=http://localhost:3000/api/translations/translate
# If backend TRANSLATION_REFRESH_KEY is set, put the same value here.
# TRANSLATION_API_TOKEN=
TRANSLATION_PROVIDER=deepl
