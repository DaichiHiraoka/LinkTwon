APP_ENV=development
NODE_ENV=development
PARTNER_APP_ROLE=event
PORT=5181
PARTNER_DB_PATH=data/partner-portal.sqlite
# Optional. If set, POST /api/translations/refresh requires x-refresh-key.
# PARTNER_REFRESH_KEY=replace-with-refresh-key
# Optional external translation API. Do not commit real tokens.
# Local default points at the main backend translation cache.
TRANSLATION_API_URL=http://localhost:3000/api/translations/translate
# If backend TRANSLATION_REFRESH_KEY is set, put the same value here.
# TRANSLATION_API_TOKEN=
TRANSLATION_PROVIDER=deepl
