# Backend runtime
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
# Optional comma-separated regex patterns for preview frontend origins.
# Example: FRONTEND_ORIGIN_PATTERNS=^https://.*\.vercel\.app$
FRONTEND_ORIGIN_PATTERNS=
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1d
# Public frontend URL used in email verification and password reset links.
# In production, set this to the deployed frontend URL.
FRONTEND_BASE_URL=http://localhost:5173
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=password123!
DEFAULT_ADMIN_ID=admin
DEFAULT_ADMIN_PASSWORD=admin123
# Set to true on Render if you cannot run the seed command from Render Shell.
AUTO_SEED_DEMO_DATA=false

# Email delivery for registration verification
# Standard runtime uses real SMTP delivery. Do not commit real credentials.
MAIL_DRIVER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM="Link Town <no-reply@example.com>"
SMTP_TLS_REJECT_UNAUTHORIZED=true
EMAIL_VERIFICATION_EXPIRES_MINUTES=1440
# Only set true in local automated tests. This exposes verification tokens in API responses.
MAIL_EXPOSE_VERIFICATION_TOKEN=false
PASSWORD_RESET_EXPIRES_MINUTES=30
# Only set true in local automated tests. This exposes reset tokens in API responses.
MAIL_EXPOSE_RESET_TOKEN=false
# Local fallback only if you intentionally do not want real delivery:
# MAIL_DRIVER=outbox
# MAIL_OUTBOX_DIR=backend/database/mail-outbox

# Render + Aiven for MySQL
# Set DATABASE_URL in Render with the value issued by Aiven.
# Do not commit real credentials.
DB_CLIENT=mysql
DATABASE_URL=mysql://avnadmin:replace-with-aiven-password@replace-with-aiven-host.aivencloud.com:12345/defaultdb?ssl-mode=REQUIRED
MYSQL_SSL=true
MYSQL_SSL_REJECT_UNAUTHORIZED=true
# MYSQL_SSL_CA=/etc/secrets/aiven-ca.pem
# DB_CONNECTION_LIMIT=10

# Local SQLite fallback for development or smoke tests
# DB_CLIENT=sqlite
# SQLITE_PATH=database/dev.sqlite

# Frontend build/runtime
# Leave empty during local Vite development and ngrok forwarding so requests use the Vite proxy.
# Set this to the public Render backend URL when building a static production frontend.
VITE_API_BASE_URL=
VITE_PROXY_TARGET=http://127.0.0.1:3000
