# LinkTwon environment files are service-scoped.
#
# Copy the relevant service example when local secret values are needed:
# - backend/.env.example -> backend/.env.local
# - frontend/.env.example -> frontend/.env.local
# - frontend-admin/.env.example -> frontend-admin/.env.local
# - partner-portals/.env.example -> partner-portals/.env.local
#
# Shared, non-secret development and test defaults are committed as:
# - backend/.env.development
# - backend/.env.test
# - frontend/.env.development
# - frontend/.env.test
# - frontend-admin/.env.development
# - frontend-admin/.env.test
# - partner-portals/.env.development
# - partner-portals/.env.test
#
# Do not commit .env.local, .env.*.local, .env.staging, or .env.production.
