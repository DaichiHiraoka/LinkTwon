# Backend runtime
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
# Optional comma-separated regex patterns for preview frontend origins.
# Example: FRONTEND_ORIGIN_PATTERNS=^https://.*\.vercel\.app$
FRONTEND_ORIGIN_PATTERNS=
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1d
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=password123
DEFAULT_ADMIN_ID=admin
DEFAULT_ADMIN_PASSWORD=admin123
# Set to true on Render if you cannot run the seed command from Render Shell.
AUTO_SEED_DEMO_DATA=false

# Render + Aiven for MySQL
# Set DATABASE_URL in Render with the value issued by Aiven.
# Do not commit real credentials.
DB_CLIENT=mysql
DATABASE_URL=mysql://avnadmin:replace-with-aiven-password@replace-with-aiven-host.aivencloud.com:12345/defaultdb?ssl-mode=REQUIRED
MYSQL_SSL=true
MYSQL_SSL_REJECT_UNAUTHORIZED=true
# MYSQL_SSL_CA=/etc/secrets/aiven-ca.pem
# DB_CONNECTION_LIMIT=10

# Local SQLite fallback for development or smoke tests
# DB_CLIENT=sqlite
# SQLITE_PATH=backend/database/dev.sqlite

# Frontend build/runtime
# Leave empty during local Vite development and ngrok forwarding so requests use the Vite proxy.
# Set this to the public Render backend URL when building a static production frontend.
VITE_API_BASE_URL=
VITE_PROXY_TARGET=http://127.0.0.1:3000
