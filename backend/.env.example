APP_ENV=development
NODE_ENV=development
PORT=3000

DB_CLIENT=sqlite
SQLITE_PATH=database/dev.sqlite
# For staging/production, inject DATABASE_URL from the deployment platform.
# DATABASE_URL=mysql://user:password@host:3306/database?ssl-mode=REQUIRED
DB_CONNECTION_LIMIT=10
MYSQL_SSL=false
MYSQL_SSL_REJECT_UNAUTHORIZED=true
# MYSQL_SSL_CA=/absolute/path/to/ca.pem

JWT_SECRET=replace-with-local-secret-at-least-8-chars
JWT_EXPIRES_IN=1d

FRONTEND_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5181,http://localhost:5182
FRONTEND_ORIGIN_PATTERNS=
FRONTEND_BASE_URL=http://localhost:5173

DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=password123
DEFAULT_ADMIN_ID=admin
DEFAULT_ADMIN_PASSWORD=admin123
AUTO_SEED_DEMO_DATA=false

MAIL_DRIVER=outbox
MAIL_OUTBOX_DIR=database/mail-outbox
EMAIL_VERIFICATION_EXPIRES_MINUTES=1440
MAIL_EXPOSE_VERIFICATION_TOKEN=false
PASSWORD_RESET_EXPIRES_MINUTES=30
MAIL_EXPOSE_RESET_TOKEN=false

# Required only when MAIL_DRIVER=smtp.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=replace-with-smtp-user
# SMTP_PASSWORD=replace-with-smtp-password
# SMTP_FROM=Link Town <no-reply@example.com>
# SMTP_TLS_REJECT_UNAUTHORIZED=true
# Required only when MAIL_DRIVER=resend.
# RESEND_API_KEY=replace-with-resend-api-key
